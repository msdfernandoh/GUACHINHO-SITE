# Copie para .env.local e preencha com o projeto Supabase.
# Template idêntico ao da raiz do repositório (../.env.example).

# Supabase (obrigatório)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Apenas servidor — NUNCA expor no client nem marcar como pública na Vercel
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# URL do site (redirects Auth, links absolutos)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Produção (Vercel): cadastre as mesmas chaves em Production + Preview
# NEXT_PUBLIC_SITE_URL=https://seu-app.vercel.app
